# Server Configuration
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe Secret Key (TEST mode only — starts with sk_test_)
# Get yours at: https://dashboard.stripe.com/test/apikeys
# Leave blank to disable automatic payment processing
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# HDX/HAPI App Identifier (optional — helps with rate limiting)
# Register at: https://hapi.humdata.org/docs/#/Authentication/get_api_v1_encode_identifier
HDX_APP_IDENTIFIER=disaster-aid-verifier-hackathon
