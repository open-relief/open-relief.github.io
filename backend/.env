# Optional default key id from your wallet provider (can also be supplied in form)
KEY_ID=

# Optional default absolute path to private key file (can also be supplied in form)
# PRIVATE_KEY_PATH=C:/Users/you/Downloads/private.key
PRIVATE_KEY_PATH=

# Donation recipient account (required for donations page to work)
DONATION_RECIPIENT_KEY_ID=
DONATION_RECIPIENT_PRIVATE_KEY_PATH=
DONATION_RECIPIENT_WALLET_ADDRESS=

# Admin login credentials
ADMIN_USER_EMAIL=admin@openrelief.org
ADMIN_USER_PASSWORD=openrelief-admin

# Optional: admin session lifetime in milliseconds (default 8 hours)
ADMIN_SESSION_TTL_MS=28800000

# Optional: user session lifetime in milliseconds (default 8 hours)
USER_SESSION_TTL_MS=28800000

# Auto-approval agent settings
# Requests must be strictly below this amount to be auto-approved.
AUTO_APPROVAL_MAX_UNITS=100000

# Needy household criteria and bonus top-up for approved amount.
NEEDY_HOUSEHOLD_MIN=5
NEEDY_PER_CAPITA_MAX_SGD=1300
NEEDY_AMOUNT_BONUS_UNITS=10000

# Agent polling interval for open requests.
AUTO_APPROVAL_AGENT_INTERVAL_MS=30000

# Optional: base URL used in the interactive grant callback
# Keep this aligned with where your server is reachable from the browser.
PUBLIC_BASE_URL=http://10.197.214.67:3001

# Optional: server port
PORT=3001

# Optional: when true, callback hash mismatch fails the transfer.
# For demo reliability this defaults to false.
ENFORCE_CALLBACK_HASH=false

GEMINI_API_KEY=AIzaSyAVDWAO37JFkMpJisuyh_9hXTV8lp_guZY
