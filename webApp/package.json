{
  "name": "webApp",
  "version": "1.0.0",
  "description": "Web application that uses Kotlin Multiplatform Library",
  "type": "module",
  "scripts": {
    // build the Kotlin/JS shared library first, then let Vite produce the static bundle
    "prestart": "../gradlew :shared:jsBrowserDevelopmentLibraryDistribution",
    "start": "vite",

    // production build: compile shared code and then run Vite's build command
    "build": "../gradlew :shared:jsBrowserProductionLibraryDistribution && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shared": "0.0.0-unspecified"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.2",
    "vite": "^7.1.6"
  }
}
